generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String?
  createdAt DateTime @default(now())
}

enum AppointmentStatus {
  NEW
  CONFIRMED
  CANCELLED
  DONE
}

model Appointment {
  id        String            @id @default(cuid())
  name      String
  phone     String
  email     String?
  service   String?
  date      DateTime
  note      String?
  status    AppointmentStatus @default(NEW)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}